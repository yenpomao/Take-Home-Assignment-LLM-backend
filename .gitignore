# Ignore everything under .claude/
.claude/**

# But do NOT ignore files directly under .claude/
!.claude/*
# Re-ignore any folders directly under .claude/ (will catch folders again)
.claude/*/

# EXCEPT allow the .claude/commands/ folder and its contents
!.claude/commands/
.claude/commands/**

# EXCEPT allow the .claude/commands/ folder and its contents
!.claude/templates/

# Specifically ignore .claude/settings.local.json
.claude/settings.local.json
.cursor

